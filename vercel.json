{
  "rewrites": [
    {
      "source": "/share/:username/:code",
      "destination": "/share/profile"
    },
    {
      "source": "/profile",
      "destination": "/profile"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "redirects": []
}
